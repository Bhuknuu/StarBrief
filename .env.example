# ══════════════════════════════════════════════════════════
# StarBrief — Environment Variables Template
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════

# ─── Neon PostgreSQL ───
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/starbrief?sslmode=require

# ─── LLM (Hybrid Router via LiteLLM) ───
GEMINI_API_KEY=your-gemini-api-key-here     # fallback 
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx       # primary  


# ─── GitHub PAT (for GitHub Issues scraper) ───
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Reddit API (for Reddit scraper — Phase 2) ───
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=StarBrief/0.1

# ─── SerpAPI (for LinkedIn/Google Jobs — Phase 2) ───
SERPAPI_KEY=

# ─── Vercel Webhook Secret (protects trigger endpoints) ───
WEBHOOK_SECRET=generate-a-random-secret-here

# ─── App Config ───
LOG_LEVEL=INFO
ENVIRONMENT=development
